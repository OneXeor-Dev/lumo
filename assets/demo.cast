[10.32, "o", "FOUND  6 parity findings (1 high, 2 info, 3 medium)\r\n"]
[10.36, "o", "       confidence: measured\r\n"]
[10.4, "o", "       android: measured, ios: measured\r\n"]
[10.44, "o", "\r\n"]
[10.48, "o", "  1. [HIGH    ] component_missing_on_ios\r\n"]
[10.52, "o", "     element: fab_add\r\n"]
[10.56, "o", "     android: present    ios: missing\r\n"]
[10.6, "o", "     Element 'fab_add' exists on Android but not on iOS.\r\n"]
[10.64, "o", "     \u2192 Implement the matching element on iOS, or remove it from Android if the feature was intentionally Android-only.\r\n"]
[10.68, "o", "\r\n"]
[10.72, "o", "  2. [MEDIUM  ] height_mismatch\r\n"]
[10.76, "o", "     element: card_offer\r\n"]
[10.8, "o", "     android: 16.0    ios: 48.0\r\n"]
[10.84, "o", "     'card_offer' height differs between platforms: Android 16.0dp vs iOS 48.0pt. dp and pt are both density-independent and should match.\r\n"]
[10.88, "o", "     \u2192 Align both platforms to the same height value. If the intent is platform-specific, declare it in lumo.config.json to suppress this finding.\r\n"]
[10.92, "o", "\r\n"]
[10.96, "o", "  3. [MEDIUM  ] width_mismatch\r\n"]
[11.0, "o", "     element: card_offer\r\n"]
[11.04, "o", "     android: 363.0    ios: 353.0\r\n"]
[11.08, "o", "     'card_offer' width differs between platforms: Android 363.0dp vs iOS 353.0pt. dp and pt are both density-independent and should match.\r\n"]
[11.12, "o", "     \u2192 Align both platforms to the same width value. If the intent is platform-specific, declare it in lumo.config.json to suppress this finding.\r\n"]
[11.16, "o", "\r\n"]
[11.2, "o", "  4. [MEDIUM  ] width_mismatch\r\n"]
[11.24, "o", "     element: cta_continue\r\n"]
[11.28, "o", "     android: 363.0    ios: 353.0\r\n"]
[11.32, "o", "     'cta_continue' width differs between platforms: Android 363.0dp vs iOS 353.0pt. dp and pt are both density-independent and should match.\r\n"]
[11.36, "o", "     \u2192 Align both platforms to the same width value. If the intent is platform-specific, declare it in lumo.config.json to suppress this finding.\r\n"]
[11.4, "o", "\r\n"]
[11.44, "o", "  5. [INFO    ] platform_specific_default\r\n"]
[11.48, "o", "     element: nav_back\r\n"]
[11.52, "o", "     android: 48.0    ios: 44.0\r\n"]
[11.56, "o", "     'nav_back' width differs by design: 48.0dp / 44.0pt. Minimum touch target: Material 48dp vs Apple HIG 44pt.\r\n"]
[11.6, "o", "     \u2192 This is a known platform convention \u2014 no action needed unless the design system explicitly overrides it.\r\n"]
[11.64, "o", "\r\n"]
[11.68, "o", "  6. [INFO    ] platform_specific_default\r\n"]
[11.72, "o", "     element: nav_back\r\n"]
[11.76, "o", "     android: 48.0    ios: 44.0\r\n"]
[11.8, "o", "     'nav_back' height differs by design: 48.0dp / 44.0pt. Minimum touch target: Material 48dp vs Apple HIG 44pt.\r\n"]
[11.84, "o", "     \u2192 This is a known platform convention \u2014 no action needed unless the design system explicitly overrides it.\r\n"]
[11.88, "o", "\r\n"]
